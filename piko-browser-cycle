#!/bin/bash
set -euo pipefail

PIKO_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
PIKO_LIB_DIR="$(cd "$(dirname "$PIKO_SELF")" && pwd)"
source "${PIKO_LIB_DIR}/piko-lib"

GRACE_SECONDS=5

usage() {
    echo "Usage: piko-browser-cycle <lock|unlock>"
}

if [ "${EUID}" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

[ "$#" -eq 1 ] || { usage; exit 1; }
MODE=$1
case "$MODE" in
    lock|unlock) ;;
    *) usage; exit 1 ;;
esac

collect_pids() {
    for name in "${PIKO_BROWSERS[@]}"; do
        pgrep -x "$name" 2>/dev/null || true
    done | sort -u
}

PIDS=$(collect_pids)
if [ -z "$PIDS" ]; then
    if [ "$MODE" = "unlock" ]; then
        mkdir -p "$PIKO_STATE_DIR"
        date +%s > "$PIKO_LAST_UNLOCK_FILE"
        _piko_fix_permissions
    fi
    exit 0
fi

PID_COUNT=$(echo "$PIDS" | wc -l | tr -d ' ')
logger "Piko: browser cycle($MODE) started — $PID_COUNT browser process(es)"

# --- Graceful warning before killing ---
# Give users a few seconds to save their work.
if [ "$MODE" = "lock" ]; then
    piko_notify "Piko" "Browsers will restart in ${GRACE_SECONDS}s to apply blocking. Save your work."
else
    piko_notify "Piko" "Browsers will restart in ${GRACE_SECONDS}s to clear blocking."
fi
sleep "$GRACE_SECONDS"

# Re-collect PIDs (some may have closed voluntarily after notification)
PIDS=$(collect_pids)
if [ -z "$PIDS" ]; then
    logger "Piko: browser cycle($MODE) all browsers closed voluntarily"
    if [ "$MODE" = "unlock" ]; then
        mkdir -p "$PIKO_STATE_DIR"
        date +%s > "$PIKO_LAST_UNLOCK_FILE"
        _piko_fix_permissions
    fi
    exit 0
fi

# Send SIGTERM (graceful close)
while IFS= read -r pid; do
    [ -z "$pid" ] && continue
    kill -TERM "$pid" 2>/dev/null || true
done <<< "$PIDS"

# Wait up to 8 seconds for graceful shutdown
for _ in 1 2 3 4 5 6 7 8; do
    sleep 1
    REMAINING=""
    while IFS= read -r pid; do
        [ -z "$pid" ] && continue
        if kill -0 "$pid" 2>/dev/null; then
            REMAINING+="$pid "$'\n'
        fi
    done <<< "$PIDS"

    if [ -z "$REMAINING" ]; then
        logger "Piko: browser cycle($MODE) graceful close complete"
        if [ "$MODE" = "unlock" ]; then
            mkdir -p "$PIKO_STATE_DIR"
            date +%s > "$PIKO_LAST_UNLOCK_FILE"
            _piko_fix_permissions
        fi
        exit 0
    fi
done

# Force-kill remaining processes
while IFS= read -r pid; do
    [ -z "$pid" ] && continue
    kill -KILL "$pid" 2>/dev/null || true
done <<< "$PIDS"

logger "Piko: browser cycle($MODE) force close applied"

if [ "$MODE" = "unlock" ]; then
    mkdir -p "$PIKO_STATE_DIR"
    date +%s > "$PIKO_LAST_UNLOCK_FILE"
    _piko_fix_permissions
fi