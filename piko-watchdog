#!/bin/bash
set -e

PIKO_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
PIKO_LIB_DIR="$(cd "$(dirname "$PIKO_SELF")" && pwd)"
source "${PIKO_LIB_DIR}/piko-lib"

[ ! -f "$PIKO_UNLOCK_FILE" ] && exit 0

UNLOCK_AT=$(cat "$PIKO_UNLOCK_FILE")
# Validate unlock_at is numeric
[[ "$UNLOCK_AT" =~ ^[0-9]+$ ]] || exit 0

NOW=$(date +%s)

REQUEST_AT=0
if [ -f "$PIKO_REQUEST_FILE" ]; then
    REQUEST_AT=$(cat "$PIKO_REQUEST_FILE")
fi

SHOULD_UNLOCK=0
if [ "$NOW" -ge "$UNLOCK_AT" ]; then
    SHOULD_UNLOCK=1
fi
if [ "$REQUEST_AT" -gt 0 ] && [ "$NOW" -ge "$REQUEST_AT" ]; then
    SHOULD_UNLOCK=1
fi

if [ "$SHOULD_UNLOCK" -eq 1 ]; then
    chattr -i "$PIKO_HOSTS"
    sed -i '/# piko:/d' "$PIKO_HOSTS"
    rm -f "$PIKO_UNLOCK_FILE"
    rm -f "$PIKO_REQUEST_FILE"
    rm -f "$PIKO_DOMAINS_FILE"
    "$PIKO_BIN_DIR/piko-browser-guard" clear || logger "Piko: browser guard clear failed"
    "$PIKO_BIN_DIR/piko-browser-cycle" unlock || logger "Piko: browser cycle unlock failed"
    systemctl try-restart systemd-resolved 2>/dev/null || true
    _piko_fix_permissions
    piko_log "INFO" "Session ended (watchdog unlocked)"
    piko_history_append "unlock"
    piko_notify "Piko" "Your focus session has ended. Sites unblocked."
    logger "Piko: session ended, hosts file unblocked"
else
    chattr -i "$PIKO_HOSTS" 2>/dev/null || true
    if [ -f "$PIKO_DOMAINS_FILE" ]; then
        while IFS= read -r domain; do
            [ -z "$domain" ] && continue
            grep -q "# piko:${domain}:ipv4" "$PIKO_HOSTS" || \
                echo "127.0.0.1 $domain www.$domain # piko:${domain}:ipv4" >> "$PIKO_HOSTS"
            grep -q "# piko:${domain}:ipv6" "$PIKO_HOSTS" || \
                echo "::1 $domain www.$domain # piko:${domain}:ipv6" >> "$PIKO_HOSTS"
        done < "$PIKO_DOMAINS_FILE"
    fi
    "$PIKO_BIN_DIR/piko-browser-guard" apply || logger "Piko: browser guard apply failed"
    chattr +i "$PIKO_HOSTS"
    _piko_fix_permissions
fi