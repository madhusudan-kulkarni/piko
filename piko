#!/bin/bash
set -eo pipefail

# Resolve symlink so we find piko-lib correctly
# (important when invoked via /usr/local/bin/piko symlink)
PIKO_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
PIKO_LIB_DIR="$(cd "$(dirname "$PIKO_SELF")" && pwd)"
source "${PIKO_LIB_DIR}/piko-lib"

PIKO_ORIGINAL_ARGS=("$@")

# ============================================================
# Command: help
# ============================================================

cmd_help() {
    echo ""
    echo "${_C_BOLD}  piko${_C_RESET} ${_C_DIM}— high-friction website blocker${_C_RESET}"
    echo ""
    cat <<EOF
${_C_BOLD}Usage:${_C_RESET} piko <command> [options]

${_C_BOLD}Commands:${_C_RESET}
  ${_C_GREEN}block${_C_RESET} <minutes> [domains...]  Start a blocking session
  ${_C_GREEN}extend${_C_RESET} <minutes>             Extend the current session
  ${_C_GREEN}schedule${_C_RESET}                       Manage automated blocking schedules
  ${_C_GREEN}status${_C_RESET}                        Show current block status
  ${_C_GREEN}stats${_C_RESET}                         Show beautiful focus statistics
  ${_C_GREEN}unlock${_C_RESET} [minutes]              Request early unlock after cooldown
  ${_C_GREEN}check${_C_RESET}                         Verify block consistency
  ${_C_GREEN}history${_C_RESET}                       Show past sessions
  ${_C_GREEN}uninstall${_C_RESET}                     Remove Piko from your system

${_C_BOLD}Options:${_C_RESET}
  --version                     Show version
  -h, --help                    Show this help

Run ${_C_DIM}piko <command> --help${_C_RESET} for details on a command.

${_C_BOLD}Examples:${_C_RESET}
  piko block 60 instagram.com youtube.com
  piko block --preset social 90
  piko extend 30
  piko stats
  piko status
  piko unlock 30
  piko check
  piko history --week
EOF
}

# ============================================================
# Command: block
# ============================================================

cmd_block() {
    local PRESETS=()
    local DOMAINS=()
    local MINUTES=""
    local FORCE=0
    local DRY_RUN=0

    # Scan for early-exit flags first (no root needed)
    for arg in "$@"; do
        case "$arg" in
            -l|--list)
                list_presets
                exit 0
                ;;
            -h|--help)
                cat <<'EOF'
Usage: piko block <minutes> [options] [domains...]

Start a blocking session.

Arguments:
  minutes              Duration in minutes (default: 60, or PIKO_DEFAULT_DURATION)
  domains              Websites to block (e.g. instagram.com)

Options:
  -p, --preset NAME    Add preset blocklist (can be repeated)
  --list               List available presets
  --force              Replace existing session instead of erroring
  --dry-run            Show what would be blocked without applying
  -h, --help           Show this help

Examples:
  piko block 60 instagram.com youtube.com
  piko block --preset social 90
  piko block -p social -p news 30
  piko block --list
EOF
                exit 0
                ;;
        esac
    done

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            -p|--preset)
                if [ -z "${2:-}" ] || [[ "${2:-}" = -* ]]; then
                    piko_error "--preset requires a name"
                    echo ""
                    echo "  piko block --list       # see available presets"
                    echo "  piko block 60 --preset social"
                    exit 1
                fi
                PRESETS+=("$2")
                shift 2
                ;;
            --force)
                FORCE=1
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                shift
                ;;
            *)
                if [ -z "$MINUTES" ] && [[ "$1" =~ ^-?[0-9]+$ ]]; then
                    MINUTES="$1"
                else
                    DOMAINS+=("$1")
                fi
                shift
                ;;
        esac
    done

    # Default duration
    if [ -z "$MINUTES" ]; then
        load_config
        MINUTES=$(get_default_duration)
    fi

    # Validate duration
    if ! [[ "$MINUTES" =~ ^[0-9]+$ ]] || [ "$MINUTES" -le 0 ]; then
        piko_error "duration must be a positive number (got: ${MINUTES:-empty})"
        echo ""
        echo "  piko block 60 instagram.com"
        echo "  piko block --preset social"
        exit 1
    fi

    # Resolve presets
    for preset in "${PRESETS[@]}"; do
        local domains_str
        domains_str=$(get_preset_domains "$preset")
        if [ -z "$domains_str" ]; then
            piko_error "unknown preset '$preset'"
            echo ""
            echo "  piko block --list    # see available presets"
            exit 1
        fi
        IFS=',' read -ra ADDR <<< "$domains_str"
        for d in "${ADDR[@]}"; do
            d=$(echo "$d" | xargs)
            [ -n "$d" ] && DOMAINS+=("$d")
        done
    done

    # Check for active session
    if is_active_session && [ "$FORCE" -eq 0 ] && [ "$DRY_RUN" -eq 0 ]; then
        local unlock_at remaining
        unlock_at=$(cat "$PIKO_UNLOCK_FILE")
        remaining=$(( unlock_at - $(date +%s) ))
        piko_error "already in an active block session ($(fmt_duration "$remaining") remaining)"
        echo ""
        echo "  piko status           # see current session details"
        echo "  piko extend 30        # extend current session by 30 minutes"
        echo "  piko unlock 30        # request early unlock (30 min cooldown)"
        echo "  piko block --force .. # replace current session"
        exit 1
    fi

    # If forcing, merge existing domains
    if [ "$FORCE" -eq 1 ] && [ -f "$PIKO_DOMAINS_FILE" ]; then
        while IFS= read -r d; do
            [ -z "$d" ] && continue
            DOMAINS+=("$d")
        done < "$PIKO_DOMAINS_FILE"
    fi

    # Validate we have domains
    if [ ${#DOMAINS[@]} -eq 0 ]; then
        piko_error "no sites specified"
        echo ""
        echo "  piko block 60 instagram.com youtube.com"
        echo "  piko block --preset social"
        echo "  piko block --list       # see all presets"
        exit 1
    fi

    # Normalize all domains before any action
    local NORMALIZED=()
    for domain in "${DOMAINS[@]}"; do
        domain=${domain,,}
        domain=${domain#http://}
        domain=${domain#https://}
        domain=${domain%%/*}
        domain=${domain#www.}
        [ -z "$domain" ] && continue
        NORMALIZED+=("$domain")
    done
    DOMAINS=("${NORMALIZED[@]}")

    # Dry-run mode: show what would happen and exit
    if [ "$DRY_RUN" -eq 1 ]; then
        local browser_count
        browser_count=$(count_browser_pids)
        echo ""
        piko_header "Dry run — no changes will be made"
        echo ""
        echo "  ${_C_BOLD}Duration:${_C_RESET}    ${MINUTES} minute$([ "$MINUTES" -ne 1 ] && echo 's')"
        echo "  ${_C_BOLD}Sites:${_C_RESET}       ${#DOMAINS[@]}"
        for d in "${DOMAINS[@]}"; do
            echo "               ${_C_DIM}${d}, www.${d}${_C_RESET}"
        done
        echo "  ${_C_BOLD}Hosts:${_C_RESET}       $(( ${#DOMAINS[@]} * 2 )) entries (IPv4 + IPv6)"
        echo "  ${_C_BOLD}Policies:${_C_RESET}    Firefox, Chrome, Chromium, Brave, Edge"
        echo "  ${_C_BOLD}DoH:${_C_RESET}         will be disabled in all browsers"
        echo "  ${_C_BOLD}Browsers:${_C_RESET}    ${browser_count} running (will be restarted)"
        echo ""
        exit 0
    fi

    # Need root from here
    check_deps || exit 1
    ensure_root

    mkdir -p "$PIKO_STATE_DIR"

    # Unlock hosts file for editing
    chattr -i "$PIKO_HOSTS" 2>/dev/null || true

    # Clear and rewrite domains file
    : > "$PIKO_DOMAINS_FILE"
    for domain in "${DOMAINS[@]}"; do
        [ -z "$domain" ] && continue

        # Deduplicate
        if ! grep -qx "$domain" "$PIKO_DOMAINS_FILE" 2>/dev/null; then
            printf '%s\n' "$domain" >> "$PIKO_DOMAINS_FILE"
        fi

        # Add hosts entries
        grep -q "# piko:${domain}:ipv4" "$PIKO_HOSTS" 2>/dev/null || \
            echo "127.0.0.1 $domain www.$domain # piko:${domain}:ipv4" >> "$PIKO_HOSTS"
        grep -q "# piko:${domain}:ipv6" "$PIKO_HOSTS" 2>/dev/null || \
            echo "::1 $domain www.$domain # piko:${domain}:ipv6" >> "$PIKO_HOSTS"
    done

    # Set unlock timer
    date -d "+${MINUTES} minutes" +%s > "$PIKO_UNLOCK_FILE"

    # Write owner file for permission fixups when running via systemd
    _piko_real_user > "$PIKO_OWNER_FILE"

    # Lock hosts file
    chattr +i "$PIKO_HOSTS"

    # Clear any pending unlock request (new session supersedes it)
    rm -f "$PIKO_REQUEST_FILE"

    # Apply browser blocking
    if ! "$PIKO_BIN_DIR/piko-browser-guard" apply 2>&1; then
        piko_warn "browser policy failed to apply — sites may still be accessible in browsers until restart"
    fi
    if ! "$PIKO_BIN_DIR/piko-browser-cycle" lock 2>&1; then
        piko_warn "could not restart browsers — please restart them manually for full blocking"
    fi

    # Restart DNS resolver
    systemctl try-restart systemd-resolved 2>/dev/null || true

    # Fix file ownership so piko status (no sudo) can read them
    _piko_fix_permissions

    # Log the action
    local domain_list
    domain_list=$(sed ':a;N;$!ba;s/\n/,/g' "$PIKO_DOMAINS_FILE")
    piko_log "INFO" "Session started: ${MINUTES}m, domains: ${domain_list}"
    piko_history_append "block" "duration=${MINUTES}" "domains=[\"$(sed ':a;N;$!ba;s/\n/\",\"/g' "$PIKO_DOMAINS_FILE")\"]"
    piko_notify "Piko" "Blocking ${domain_count:-0} sites for ${MINUTES} minutes. Stay focused."

    # Print success
    local unlock_at remaining_human domain_count
    unlock_at=$(cat "$PIKO_UNLOCK_FILE")
    remaining_human=$(fmt_time "$unlock_at")
    domain_count=$(wc -l < "$PIKO_DOMAINS_FILE" | tr -d ' ')

    echo ""
    piko_success "Blocked ${_C_BOLD}${domain_count}${_C_RESET} site$([ "$domain_count" -ne 1 ] && echo 's') for ${_C_BOLD}${MINUTES}${_C_RESET} minute$([ "$MINUTES" -ne 1 ] && echo 's') ${_C_DIM}(unlocks at ${remaining_human})${_C_RESET}"
    echo ""
    echo "  ${_C_DIM}$(sed ':a;N;$!ba;s/\n/, /g' "$PIKO_DOMAINS_FILE")${_C_RESET}"
    echo ""
    echo "  Browsers were restarted. DNS-over-HTTPS disabled."
    echo "  ${_C_DIM}Stay focused.${_C_RESET}"
}

# ============================================================
# Command: status
# ============================================================

cmd_status() {
    local quiet=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -q|--quiet) quiet=1; shift ;;
            -h|--help)
                cat <<'EOF'
Usage: piko status [options]

Show current blocking status.

Options:
  -q, --quiet    Exit code only: 0=unblocked, 1=blocked, 2=hosts stale, 3=policies stale, 4=browser restart needed
  -h, --help     Show this help

Examples:
  piko status           # show current status
  piko status --quiet   # exit code only (for scripts)
EOF
                exit 0
                ;;
            *) shift ;;
        esac
    done

    # Quiet mode: exit codes only
    if [ "$quiet" -eq 1 ]; then
        if is_active_session; then
            exit 1
        fi

        if grep -q '# piko:' "$PIKO_HOSTS" 2>/dev/null; then
            exit 2
        fi

        if browser_policy_active; then
            exit 3
        fi

        if browser_restart_required; then
            exit 4
        fi

        exit 0
    fi

    # Verbose mode
    if ! is_active_session; then
        echo ""
        echo "  ${_C_DIM}No active block session.${_C_RESET}"
        echo ""
        echo "  Start one:"
        echo "    piko block 60 instagram.com youtube.com"
        echo "    piko block --preset social"
        exit 0
    fi

    local unlock_at now remaining
    unlock_at=$(cat "$PIKO_UNLOCK_FILE" 2>/dev/null)
    now=$(date +%s)
    remaining=$(( unlock_at - now ))

    echo ""
    if [ "$remaining" -le 0 ]; then
        echo "  ${_C_YELLOW}${_C_BOLD}Block session expired${_C_RESET} ${_C_DIM}(watchdog will clean up within 60s)${_C_RESET}"
    else
        echo "  ${_C_RED}${_C_BOLD}Blocked${_C_RESET} for ${_C_BOLD}$(fmt_duration "$remaining")${_C_RESET} more ${_C_DIM}(unlocks at $(fmt_time "$unlock_at"))${_C_RESET}"
    fi

    echo ""

    # Show domains
    if [ -f "$PIKO_DOMAINS_FILE" ]; then
        echo "  ${_C_BOLD}Sites:${_C_RESET}          ${_C_DIM}$(sed ':a;N;$!ba;s/\n/, /g' "$PIKO_DOMAINS_FILE")${_C_RESET}"
    fi

    # Browser blocking status
    if browser_policy_active; then
        echo "  ${_C_BOLD}Browser:${_C_RESET}        ${_C_GREEN}active${_C_RESET} ${_C_DIM}(DoH disabled)${_C_RESET}"
    else
        echo "  ${_C_BOLD}Browser:${_C_RESET}        ${_C_YELLOW}not active${_C_RESET}"
    fi

    # Coerced unlock status
    if [ -f "$PIKO_REQUEST_FILE" ]; then
        local request_at request_remaining
        request_at=$(cat "$PIKO_REQUEST_FILE")
        request_remaining=$(( request_at - now ))
        if [ "$request_remaining" -le 0 ]; then
            echo "  ${_C_BOLD}Early unlock:${_C_RESET}   ${_C_GREEN}due now${_C_RESET} ${_C_DIM}(watchdog processing within 60s)${_C_RESET}"
        else
            echo "  ${_C_BOLD}Early unlock:${_C_RESET}   ${_C_YELLOW}$(fmt_duration "$request_remaining") of cooldown remaining${_C_RESET}"
        fi
    fi
    echo ""
}

# ============================================================
# Command: unlock
# ============================================================

cmd_unlock() {
    local minutes=""
    local now_mode=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --now) now_mode=1; shift ;;
            -h|--help)
                cat <<'EOF'
Usage: piko unlock [minutes] [--now]

Request early unlock after a cooldown period.
The cooldown cannot be cancelled or shortened once requested.

Arguments:
  minutes       Cooldown delay in minutes (default: 30)

Options:
  --now         Emergency immediate unblock (requires sudo)
  -h, --help    Show this help

Examples:
  piko unlock 30       # request unlock after 30-minute cooldown
  piko unlock          # use default 30-minute cooldown
  piko unlock --now    # emergency unblock (requires root password)
EOF
                exit 0
                ;;
            *)
                if [ -z "$minutes" ] && [[ "$1" =~ ^[0-9]+$ ]]; then
                    minutes="$1"
                fi
                shift
                ;;
        esac
    done

    if [ "$now_mode" -eq 1 ]; then
        cmd_unlock_now
        return
    fi

    # Coerced unlock with cooldown
    [ -z "$minutes" ] && minutes=30

    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [ "$minutes" -le 0 ]; then
        piko_error "cooldown must be a positive number of minutes"
        echo ""
        echo "  piko unlock 30      # 30 minute cooldown"
        exit 1
    fi

    if ! is_active_session; then
        echo "No active block session."
        echo ""
        echo "Start one: piko block 60 instagram.com"
        exit 0
    fi

    ensure_root

    local now request_at
    now=$(date +%s)
    request_at=$(( now + minutes * 60 ))

    if [ -f "$PIKO_REQUEST_FILE" ]; then
        local existing
        existing=$(cat "$PIKO_REQUEST_FILE")
        if [ "$request_at" -lt "$existing" ]; then
            piko_error "an earlier unlock is already requested (at $(fmt_time "$existing"))"
            echo "You cannot shorten an existing cooldown."
            exit 1
        fi
    fi

    mkdir -p "$PIKO_STATE_DIR"
    printf '%s\n' "$request_at" > "$PIKO_REQUEST_FILE"
    systemctl start piko-watchdog.service 2>/dev/null || true

    # Fix permissions
    _piko_fix_permissions
    piko_log "INFO" "Early unlock requested: ${minutes}m cooldown"

    echo ""
    piko_success "Early unlock requested ${_C_DIM}(${minutes}-minute cooldown)${_C_RESET}"
    echo "  ${_C_DIM}You cannot cancel this. Unlocks at $(fmt_time "$request_at").${_C_RESET}"
    echo ""
}

cmd_unlock_now() {
    ensure_root

    if [ ! -f "$PIKO_UNLOCK_FILE" ]; then
        echo "No active block session to remove."
        exit 0
    fi

    echo "This will remove all blocks immediately, skipping the cooldown."
    echo "This defeats the purpose of Piko."
    echo ""
    read -r -p "Type 'yes' to confirm: " confirm
    [ "$confirm" != "yes" ] && echo "Aborted." && exit 1

    chattr -i "$PIKO_HOSTS" 2>/dev/null || true
    sed -i '/# piko:/d' "$PIKO_HOSTS"
    rm -f "$PIKO_UNLOCK_FILE"
    rm -f "$PIKO_REQUEST_FILE"
    rm -f "$PIKO_DOMAINS_FILE"

    if ! "$PIKO_BIN_DIR/piko-browser-guard" clear 2>&1; then
        piko_warn "could not clear browser policies — try restarting your browser"
    fi
    if ! "$PIKO_BIN_DIR/piko-browser-cycle" unlock 2>&1; then
        piko_warn "could not restart browsers — try restarting them manually"
    fi

    systemctl try-restart systemd-resolved 2>/dev/null || true
    piko_log "INFO" "Emergency unblock performed"
    piko_history_append "unlock" "method=emergency"
    echo ""
    piko_success "All blocks removed."
    echo ""
}

# ============================================================
# Command: check
# ============================================================

cmd_check() {
    [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
        cat <<'EOF'
Usage: piko check

Verify that your blocking session is consistent.
Checks that hosts file, browser policies, and session state all agree.

Exit codes:
  0   Everything is consistent
  1   Drift detected (active session but enforcement missing)
  2   Stale artifacts (no session but blocking remnants)
  3   Browser restart required after unlock

Examples:
  piko check
EOF
        exit 0
    }

    local active_session=0
    if is_active_session; then
        active_session=1
    fi

    local hosts_count
    hosts_count=$(grep -c '# piko:' "$PIKO_HOSTS" 2>/dev/null || true)
    hosts_count=${hosts_count:-0}

    local policy_present=0
    browser_policy_active && policy_present=1

    local request_pending=0
    [ -f "$PIKO_REQUEST_FILE" ] && request_pending=1

    local browser_count
    browser_count=$(count_browser_pids)

    echo ""
    if [ "$active_session" -eq 1 ]; then
        local unlock_at remaining
        unlock_at=$(cat "$PIKO_UNLOCK_FILE" 2>/dev/null)
        remaining=$(( unlock_at - $(date +%s) ))
        if [ "$remaining" -le 0 ]; then
            echo "  ${_C_BOLD}Session:${_C_RESET}    ${_C_YELLOW}expired${_C_RESET} ${_C_DIM}(watchdog cleaning up)${_C_RESET}"
        else
            echo "  ${_C_BOLD}Session:${_C_RESET}    ${_C_RED}active${_C_RESET} ${_C_DIM}($(fmt_duration "$remaining") remaining)${_C_RESET}"
        fi
    else
        echo "  ${_C_BOLD}Session:${_C_RESET}    ${_C_GREEN}none${_C_RESET}"
    fi

    echo "  ${_C_BOLD}Hosts:${_C_RESET}      $([ "$hosts_count" -gt 0 ] && echo "${_C_GREEN}active${_C_RESET} ${_C_DIM}($hosts_count entries)${_C_RESET}" || echo "${_C_DIM}not active${_C_RESET}")"
    echo "  ${_C_BOLD}Browser:${_C_RESET}    $([ "$policy_present" -eq 1 ] && echo "${_C_GREEN}active${_C_RESET}" || echo "${_C_DIM}not active${_C_RESET}")"
    echo "  ${_C_BOLD}Unlock:${_C_RESET}     $([ "$request_pending" -eq 1 ] && echo "${_C_YELLOW}requested${_C_RESET}" || echo "${_C_DIM}not requested${_C_RESET}")"
    echo "  ${_C_BOLD}Browsers:${_C_RESET}   ${browser_count} running"

    # Drift: active session but no enforcement
    if [ "$active_session" -eq 1 ] && { [ "$hosts_count" -eq 0 ] || [ "$policy_present" -eq 0 ]; }; then
        echo ""
        piko_error "your block session is active but blocking is not fully enforced"
        echo ""
        echo "Try: piko block --force (re-apply blocks)"
        echo "     piko check     (verify again after)"
        exit 1
    fi

    # Stale: no session but artifacts remain
    if [ "$active_session" -eq 0 ] && { [ "$hosts_count" -gt 0 ] || [ "$policy_present" -eq 1 ]; }; then
        echo ""
        piko_error "stale blocking found (no active session but blocking remnants)"
        echo ""
        echo "Fix: piko unlock --now"
        exit 2
    fi

    # Browser restart needed after unlock
    if [ "$active_session" -eq 0 ] && browser_restart_required; then
        echo ""
        piko_error "unlocked but browser restart required for blocking to clear"
        echo ""
        echo "Fix: restart your browsers"
        exit 3
    fi

    echo ""
    piko_success "Everything looks consistent."
}

# ============================================================
# Command: uninstall
# ============================================================

cmd_uninstall() {
    [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
        cat <<'EOF'
Usage: piko uninstall

Remove Piko and all block sessions from your system.
Removes ~/.piko/, system units, browser policies, and sudoers rules.

Options:
  -h, --help    Show this help

Examples:
  piko uninstall
EOF
        exit 0
    }

    ensure_root

    echo "This will remove Piko and all block sessions from your system."
    echo ""
    read -r -p "Are you sure? Type 'yes' to confirm: " confirm
    [ "$confirm" != "yes" ] && echo "Aborted." && exit 0

    # Remove any active blocks and browser policies
    chattr -i "$PIKO_HOSTS" 2>/dev/null || true
    sed -i '/# piko:/d' "$PIKO_HOSTS"
    "$PIKO_BIN_DIR/piko-browser-guard" clear 2>/dev/null || true

    # Stop and remove systemd units (stop service too, not just timer)
    echo "Stopping services..."
    systemctl stop piko-watchdog.service piko-scheduler.service 2>/dev/null || true
    systemctl disable --now piko-watchdog.timer piko-scheduler.timer 2>/dev/null || true
    rm -f /etc/systemd/system/piko-watchdog.timer /etc/systemd/system/piko-scheduler.timer
    rm -f /etc/systemd/system/piko-watchdog.service /etc/systemd/system/piko-scheduler.service
    systemctl daemon-reload

    # Remove symlink
    rm -f /usr/local/bin/piko

    # Remove the self-contained directory
    echo "Removing piko..."
    rm -rf "$PIKO_HOME"

    # Remove sudoers
    rm -f /etc/sudoers.d/piko

    # Remove shell completions
    rm -f /etc/bash_completion.d/piko
    local piko_real_home
    piko_real_home=$(_piko_real_home)
    rm -f "${piko_real_home}/.zsh/completions/_piko" 2>/dev/null || true

    echo ""
    echo "Piko uninstalled."
}

# ============================================================
# Command: extend
# ============================================================

cmd_extend() {
    local minutes=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<'EOF'
Usage: piko extend <minutes>

Extend the current blocking session without restarting browsers.

Arguments:
  minutes       Additional time to add (in minutes)

Examples:
  piko extend 30       # Add 30 more minutes
  piko extend 60       # Add another hour
EOF
                exit 0
                ;;
            *)
                if [ -z "$minutes" ] && [[ "$1" =~ ^[0-9]+$ ]]; then
                    minutes="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$minutes" ]; then
        piko_error "specify how many minutes to add"
        echo ""
        echo "  piko extend 30"
        exit 1
    fi

    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [ "$minutes" -le 0 ]; then
        piko_error "duration must be a positive number"
        exit 1
    fi

    if ! is_active_session; then
        echo ""
        echo "  ${_C_DIM}No active block session to extend.${_C_RESET}"
        echo ""
        echo "  Start one: piko block 60 instagram.com"
        exit 0
    fi

    ensure_root

    local current_unlock_at new_unlock_at
    current_unlock_at=$(cat "$PIKO_UNLOCK_FILE")
    new_unlock_at=$(( current_unlock_at + minutes * 60 ))
    printf '%s\n' "$new_unlock_at" > "$PIKO_UNLOCK_FILE"

    _piko_fix_permissions
    piko_log "INFO" "Session extended by ${minutes} minutes"
    piko_history_append "extend" "minutes=${minutes}"
    piko_notify "Piko" "Session extended by ${minutes} minutes. Unlocks at $(fmt_time "$new_unlock_at")."

    echo ""
    piko_success "Extended by ${_C_BOLD}${minutes}${_C_RESET} minute$([ "$minutes" -ne 1 ] && echo 's') ${_C_DIM}(now unlocks at $(fmt_time "$new_unlock_at"))${_C_RESET}"
    echo ""
}

# ============================================================
# Command: history
# ============================================================

cmd_history() {
    local mode="10"

    while [ $# -gt 0 ]; do
        case "$1" in
            -n)
                mode="$2"
                shift 2
                ;;
            --week)
                mode="-week"
                shift
                ;;
            -h|--help)
                cat <<'EOF'
Usage: piko history [options]

Show past blocking sessions.

Options:
  -n COUNT       Show last COUNT entries (default: 10)
  --week         Show summary for the last 7 days
  -h, --help     Show this help

Examples:
  piko history          # show recent sessions
  piko history --week   # weekly summary
  piko history -n 20    # last 20 entries
EOF
                exit 0
                ;;
            *) shift ;;
        esac
    done

    if [ ! -f "$PIKO_HISTORY_FILE" ]; then
        echo ""
        echo "  ${_C_DIM}No history yet.${_C_RESET}"
        echo ""
        echo "  Start a session: piko block 60 instagram.com"
        exit 0
    fi

    echo ""
    python3 - "$PIKO_HISTORY_FILE" "$mode" <<'PY'
import json, sys
from datetime import datetime, timedelta
from collections import Counter

path = sys.argv[1]
mode = sys.argv[2]

entries = []
with open(path) as f:
    for line in f:
        line = line.strip()
        if line:
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass

if not entries:
    print("  No history yet.")
    sys.exit(0)

if mode == "-week":
    cutoff = int((datetime.now() - timedelta(days=7)).timestamp())
    week = [e for e in entries if e.get("ts", 0) >= cutoff]
    blocks = [e for e in week if e.get("action") == "block"]
    total_min = sum(int(e.get("duration", 0)) for e in blocks)
    hours = total_min // 60
    mins = total_min % 60
    extends = [e for e in week if e.get("action") == "extend"]
    ext_min = sum(int(e.get("minutes", 0)) for e in extends)
    total_min += ext_min
    print(f"  \033[1mLast 7 days\033[0m")
    print(f"")
    print(f"  Sessions:    {len(blocks)}")
    print(f"  Focus time:  {hours}h {mins}m")
    if ext_min > 0:
        print(f"  Extended:    +{ext_min}m across {len(extends)} extension(s)")
    if blocks:
        all_domains = []
        for e in blocks:
            d = e.get("domains", "")
            if isinstance(d, list):
                all_domains.extend(d)
            elif isinstance(d, str) and d:
                all_domains.extend(d.split(","))
        if all_domains:
            top = Counter(all_domains).most_common(5)
            print(f"  Top sites:   {', '.join(d for d, _ in top)}")
else:
    n = int(mode)
    recent = entries[-n:]
    for e in reversed(recent):
        ts = datetime.fromtimestamp(e.get("ts", 0)).strftime("%b %d %H:%M")
        action = e.get("action", "?")
        if action == "block":
            duration = e.get("duration", "?")
            domains = e.get("domains", "")
            if isinstance(domains, list):
                display = ", ".join(domains[:3])
                if len(domains) > 3:
                    display += f" +{len(domains)-3} more"
            else:
                display = str(domains)
            print(f"  \033[2m{ts}\033[0m  \033[1mblock\033[0m {duration}m  \033[2m{display}\033[0m")
        elif action == "unlock":
            print(f"  \033[2m{ts}\033[0m  \033[32munlock\033[0m")
        elif action == "extend":
            mins = e.get("minutes", "?")
            print(f"  \033[2m{ts}\033[0m  \033[36mextend\033[0m +{mins}m")
        else:
            print(f"  \033[2m{ts}\033[0m  {action}")
PY
    echo ""
}

# ============================================================
# Command: schedule
# ============================================================

cmd_schedule() {
    local action="${1:-list}"
    shift || true

    local schedule_file="$PIKO_STATE_DIR/schedules.json"

    if [ "$action" = "list" ] || [ "$action" = "-h" ] || [ "$action" = "--help" ]; then
        if [ "$action" = "-h" ] || [ "$action" = "--help" ]; then
            cat <<'EOF'
Usage: piko schedule [action] [options]

Manage automated blocking schedules.

Actions:
  list              List all schedules (default)
  add               Add a new schedule
  remove <name>     Remove a schedule

Examples:
  piko schedule add --name "Morning Focus" --days "Mon,Tue,Wed,Thu,Fri" --time "09:00" --duration 120 --preset work
  piko schedule remove "Morning Focus"
  piko schedule list
EOF
            exit 0
        fi

        if [ ! -f "$schedule_file" ]; then
            echo ""
            echo "  ${_C_DIM}No schedules defined.${_C_RESET}"
            echo ""
            exit 0
        fi

        echo ""
        echo "  ${_C_BOLD}Active Schedules:${_C_RESET}"
        echo ""
        python3 - "$schedule_file" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        schedules = json.load(f)
    if not schedules:
        print("  \033[2mNo schedules defined.\033[0m")
    for s in schedules:
        days = ", ".join(s.get('days', []))
        preset_info = f" (preset: {s.get('preset')})" if s.get('preset') else ""
        print(f"  \033[36m{s.get('name')}\033[0m")
        print(f"    {days} @ {s.get('time')} for {s.get('duration')}m{preset_info}")
        print()
except Exception as e:
    print(f"  Error reading schedules: {e}")
PY
        exit 0
    fi

    if [ "$action" = "add" ]; then
        local name="" days="" time="" duration="" preset=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --name) name="$2"; shift 2 ;;
                --days) days="$2"; shift 2 ;;
                --time) time="$2"; shift 2 ;;
                --duration) duration="$2"; shift 2 ;;
                --preset) preset="$2"; shift 2 ;;
                *) piko_error "Unknown option: $1"; exit 1 ;;
            esac
        done

        if [ -z "$name" ] || [ -z "$days" ] || [ -z "$time" ] || [ -z "$duration" ]; then
            piko_error "Missing required arguments for schedule add."
            echo "Required: --name, --days, --time, --duration"
            exit 1
        fi

        mkdir -p "$PIKO_STATE_DIR"
        [ ! -f "$schedule_file" ] && echo "[]" > "$schedule_file"

        python3 - "$schedule_file" "$name" "$days" "$time" "$duration" "$preset" <<'PY'
import json, sys
path, name, days, time, duration, preset = sys.argv[1:7]
days_list = [d.strip().capitalize()[:3] for d in days.split(",")]

with open(path, "r") as f:
    schedules = json.load(f)

# Update existing or append new
found = False
for s in schedules:
    if s["name"] == name:
        s.update({"days": days_list, "time": time, "duration": int(duration), "preset": preset if preset else None})
        found = True
        break
if not found:
    schedules.append({"name": name, "days": days_list, "time": time, "duration": int(duration), "preset": preset if preset else None})

with open(path, "w") as f:
    json.dump(schedules, f, indent=2)
PY
        _piko_fix_permissions
        piko_success "Schedule '${name}' added."
        exit 0
    fi

    if [ "$action" = "remove" ]; then
        local name="$1"
        if [ -z "$name" ]; then
            piko_error "Specify schedule name to remove"
            exit 1
        fi
        
        if [ ! -f "$schedule_file" ]; then
            piko_error "No schedules exist"
            exit 1
        fi

        if python3 - "$schedule_file" "$name" <<'PY'; then
import json, sys
path, name = sys.argv[1:3]
with open(path, "r") as f:
    schedules = json.load(f)

filtered = [s for s in schedules if s["name"] != name]
if len(filtered) == len(schedules):
    print(f"Schedule '{name}' not found.")
    sys.exit(1)

with open(path, "w") as f:
    json.dump(filtered, f, indent=2)
PY
            piko_success "Schedule '${name}' removed."
        fi
        exit 0
    fi

    piko_error "Unknown schedule action: $action"
    exit 1
}

# ============================================================
# Command: stats
# ============================================================

cmd_stats() {
    if [ ! -f "$PIKO_HISTORY_FILE" ]; then
        echo ""
        echo "  ${_C_DIM}No history yet. Start a session to see stats.${_C_RESET}"
        echo ""
        exit 0
    fi

    echo ""
    python3 - "$PIKO_HISTORY_FILE" <<'PY'
import json, sys
from datetime import datetime, timedelta
from collections import Counter

path = sys.argv[1]

entries = []
with open(path) as f:
    for line in f:
        line = line.strip()
        if line:
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass

if not entries:
    print("  \033[2mNo history yet.\033[0m")
    sys.exit(0)

# Aggregation logic
blocks = [e for e in entries if e.get("action") == "block"]
extends = [e for e in entries if e.get("action") == "extend"]

total_min = sum(int(e.get("duration", 0)) for e in blocks) + sum(int(e.get("minutes", 0)) for e in extends)
hours = total_min // 60
mins = total_min % 60

# Domains blocked
all_domains = []
for e in blocks:
    d = e.get("domains", "")
    if isinstance(d, list):
        all_domains.extend(d)
    elif isinstance(d, str) and d:
        all_domains.extend(d.split(","))
top_domains = Counter(all_domains).most_common(5)

# Calculate streak (days in a row with at least one block)
dates_with_blocks = set(datetime.fromtimestamp(e.get("ts")).date() for e in blocks)
streak = 0
today = datetime.now().date()
while (today - timedelta(days=streak)) in dates_with_blocks:
    streak += 1

# If streak is 0, check if they had a streak ending yesterday
if streak == 0:
    temp_streak = 0
    while (today - timedelta(days=temp_streak+1)) in dates_with_blocks:
        temp_streak += 1
    streak_msg = f"{temp_streak} days (ended yesterday)" if temp_streak > 0 else "0 days"
else:
    streak_msg = f"{streak} days 🔥"

# Print dashboard
print(f"  \033[1mPiko Focus Statistics\033[0m")
print(f"  \033[2m─────────────────────\033[0m")
print()
print(f"  \033[1mAll-Time Focus:\033[0m  {hours}h {mins}m")
print(f"  \033[1mTotal Sessions:\033[0m  {len(blocks)}")
print(f"  \033[1mCurrent Streak:\033[0m  {streak_msg}")
print()
if top_domains:
    print(f"  \033[1mMost Blocked Sites:\033[0m")
    for d, count in top_domains:
        bar = "█" * min(20, int((count / len(blocks)) * 20))
        print(f"    {d:<20} \033[36m{bar}\033[0m ({count})")
PY
    echo ""
}

# ============================================================
# Main dispatch
# ============================================================

if [ "${1:-}" = "--version" ]; then
    echo "${_C_BOLD}piko${_C_RESET} ${_C_DIM}${PIKO_VERSION}${_C_RESET}"
    exit 0
fi

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    block)      cmd_block "$@" ;;
    extend)     cmd_extend "$@" ;;
    schedule)   cmd_schedule "$@" ;;
    status)     cmd_status "$@" ;;
    stats)      cmd_stats "$@" ;;
    unlock)     cmd_unlock "$@" ;;
    check)      cmd_check "$@" ;;
    history)    cmd_history "$@" ;;
    uninstall)  cmd_uninstall "$@" ;;
    help|-h|--help|"") cmd_help; exit 0 ;;
    *) piko_error "unknown command '$COMMAND'"; echo ""; cmd_help >&2; exit 1 ;;
esac
